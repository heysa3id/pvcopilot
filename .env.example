# Optional: backend API base URL (used when app is built for production).
# If unset, the app uses http://localhost:5001 (works when running locally).
#
# LCOE Tool — PVsyst PDF parser
VITE_PARSER_URL=http://localhost:5001/api/parse-pvsyst
#
# Quality Check — CSV processing (PV/weather resampling)
# VITE_API_BASE=http://localhost:5001
#
# Example for production (replace with your deployed backend URL):
# VITE_PARSER_URL=https://your-backend.example.com/api/parse-pvsyst
# VITE_API_BASE=https://your-backend.example.com
